{
  "tasks": {
    "ingest": "deno run -A --unstable-ffi --env-file=.env scripts/ingest.ts",
    "index": "deno run -A --unstable-ffi --env-file=.env scripts/index.ts",
    "dev": "deno run -A --unstable-ffi --env-file=.env --watch src/server.tsx",
    "start": "deno run -A --unstable-ffi --env-file=.env src/server.tsx"
  },
  "imports": {
    "hono": "npm:hono@^4.6.0",
    "hono/jsx": "npm:hono@^4.6.0/jsx",
    "@db/sqlite": "jsr:@db/sqlite@^0.12.0",
    "sqlite-vec": "npm:sqlite-vec@^0.1.6",
    "drizzle-orm": "npm:drizzle-orm@^0.36.0",
    "drizzle-orm/": "npm:/drizzle-orm@^0.36.0/",
    "@huggingface/transformers": "npm:@huggingface/transformers@^3.0.0"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false
  }
}
