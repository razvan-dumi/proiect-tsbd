{
  "tasks": {
    "ingest": "deno run -A --env-file=.env scripts/ingest.ts",
    "reset": "deno run -A --env-file=.env scripts/reset.ts",
    "dev": "deno run -A --env-file=.env --watch src/server.tsx",
    "start": "deno run -A --env-file=.env src/server.tsx"
  },
  "imports": {
    "hono": "npm:hono@^4.6.0",
    "hono/jsx": "npm:hono@^4.6.0/jsx",
    "oracledb": "npm:oracledb@^6.6.0"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false
  }
}
